	<key>PayloadDescription</key>
	<string>This installs Dolphin's App for iOS. You can remove this whenever you want. This does nothing to your device but add an app icon to open a better optimized version of Dolphin to your device. You should not install Dolphin from anywhere else.</string>
	<key>PayloadDisplayName</key>
	<string>Dolphin: iOS Edition</string>
	<key>PayloadIdentifier</key>
	<string>Dolphin.7094D529-7A11-4D49-A02E-C2C97A8B7B6A</string>
